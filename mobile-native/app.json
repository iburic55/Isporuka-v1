{
  "expo": {
    "name": "Leadovi HR",
    "slug": "leadovi-hr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "leadovihr",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0f62fe"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "hr.leadovi.app"
    },
    "android": {
      "package": "hr.leadovi.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f62fe"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
